{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "metadata": {
    "description": "Template ARM — Déploiement complet du Lab OFPPT via Azure DevTest Labs",
    "comments": "Déploie le lab, ses politiques et les formules de VMs. Le référentiel d'artefacts s'ajoute séparément via az lab artifact-source create."
  },

  "parameters": {
    "labName": {
      "type": "string",
      "defaultValue": "ofppt-lab-formation",
      "metadata": { "description": "Nom du Lab Azure DevTest Labs" }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Région Azure" }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureofppt",
      "metadata": { "description": "Nom d'utilisateur administrateur des VMs" }
    },
    "sshPublicKey": {
      "type": "string",
      "metadata": { "description": "Clé publique SSH pour accès aux VMs" }
    },
    "autoShutdownTime": {
      "type": "string",
      "defaultValue": "2359",
      "metadata": { "description": "Heure d'arrêt de sécurité (format HHMM) — l'arrêt par durée est géré par Automation Runbook" }
    },
    "maxVmsPerUser": {
      "type": "int",
      "defaultValue": 3,
      "metadata": { "description": "Nombre maximum de VMs par stagiaire" }
    },
    "maxVmsPerLab": {
      "type": "int",
      "defaultValue": 30,
      "metadata": { "description": "Nombre maximum de VMs dans le lab" }
    }
  },

  "variables": {
    "labResourceId": "[resourceId('Microsoft.DevTestLab/labs', parameters('labName'))]",
    "vmSizeCloud":  "Standard_D4s_v3",
    "vmSizeReseau": "Standard_D2s_v3",
    "vmSizeCyber":  "Standard_D4s_v3",
    "osDiskSizeGiB": 128,
    "ubuntuImage": {
      "offer":     "0001-com-ubuntu-server-jammy",
      "publisher": "Canonical",
      "sku":       "22_04-lts-gen2",
      "osType":    "Linux",
      "version":   "latest"
    },
    "commonTags": {
      "Project":     "OFPPT-Lab",
      "Environment": "Lab",
      "Owner":       "Formation",
      "ManagedBy":   "ARM-Template"
    }
  },

  "resources": [

    {
      "type": "Microsoft.DevTestLab/labs",
      "apiVersion": "2018-09-15",
      "name": "[parameters('labName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "labStorageType": "Premium",
        "environmentPermission": "Contributor",
        "announcement": {
          "enabled": "Enabled",
          "title": "Bienvenue sur OFPPT-Lab",
          "markdown": "## Bienvenue sur la plateforme OFPPT-Lab\n\nChoisissez votre filière et créez votre VM de TP depuis les formules disponibles.\n\n**Filières disponibles :**\n- Cloud Computing (Docker, Terraform, Kubernetes)\n- Réseau & Infrastructure (Wireshark, FRRouting, VPN)\n- Cybersécurité (Metasploit, Nmap, Burp Suite)\n\n> Les VMs s'arrêtent automatiquement après 4h de fonctionnement."
        }
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/schedules",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/LabVmsShutdown')]",
      "location": "[parameters('location')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "status": "Enabled",
        "taskType": "LabVmsShutdownTask",
        "dailyRecurrence": { "time": "[parameters('autoShutdownTime')]" },
        "timeZoneId": "Romance Standard Time",
        "notificationSettings": {
          "status": "Enabled",
          "timeInMinutes": 15,
          "notificationLocale": "fr"
        }
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/policySets/policies",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/default/MaxVmsAllowedPerUser')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "status": "Enabled",
        "factName": "UserOwnedLabVmCount",
        "threshold": "[string(parameters('maxVmsPerUser'))]",
        "evaluatorType": "MaxValuePolicy",
        "description": "Limite le nombre de VMs par stagiaire"
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/policySets/policies",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/default/MaxVmsAllowedPerLab')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "status": "Enabled",
        "factName": "LabVmCount",
        "threshold": "[string(parameters('maxVmsPerLab'))]",
        "evaluatorType": "MaxValuePolicy",
        "description": "Limite le nombre total de VMs dans le lab"
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/policySets/policies",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/default/AllowedVmSizesInLab')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "status": "Enabled",
        "factName": "LabVmSize",
        "threshold": "[string(createArray('Standard_B2s','Standard_B4ms','Standard_D2s_v3','Standard_D4s_v3'))]",
        "evaluatorType": "AllowedValuesPolicy",
        "description": "Tailles de VMs autorisées"
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/formulas",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/OFPPT-Cloud-Computing')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "description": "VM filière Cloud Computing — Docker CE, Terraform 1.7, kubectl, minikube, Azure CLI, AWS CLI v2, Ansible",
        "labVirtualMachineCreationParameter": {
          "size": "[variables('vmSizeCloud')]",
          "userName": "[parameters('adminUsername')]",
          "sshKey": "[parameters('sshPublicKey')]",
          "isAuthenticationWithSshKey": true,
          "labSubnetName": "Subnet",
          "disallowPublicIpAddress": false,
          "storageType": "Premium",
          "osDiskSizeGiB": "[variables('osDiskSizeGiB')]",
          "galleryImageReference": "[variables('ubuntuImage')]",
          "notes": "Cloud Computing — Docker CE, Terraform 1.7, kubectl, minikube, Azure CLI, AWS CLI v2, Ansible, Helm"
        }
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/formulas",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/OFPPT-Reseau-Infrastructure')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "description": "VM filière Réseau — Wireshark, tcpdump, Nmap, FRRouting (OSPF/BGP/RIP), OpenVPN, WireGuard, Open vSwitch",
        "labVirtualMachineCreationParameter": {
          "size": "[variables('vmSizeReseau')]",
          "userName": "[parameters('adminUsername')]",
          "sshKey": "[parameters('sshPublicKey')]",
          "isAuthenticationWithSshKey": true,
          "labSubnetName": "Subnet",
          "disallowPublicIpAddress": false,
          "storageType": "Premium",
          "osDiskSizeGiB": "[variables('osDiskSizeGiB')]",
          "galleryImageReference": "[variables('ubuntuImage')]",
          "notes": "Réseau — Wireshark, tcpdump, Nmap, iperf3, FRRouting, OpenVPN, WireGuard, Open vSwitch"
        }
      }
    },

    {
      "type": "Microsoft.DevTestLab/labs/formulas",
      "apiVersion": "2018-09-15",
      "name": "[concat(parameters('labName'), '/OFPPT-Cybersecurite')]",
      "dependsOn": [ "[variables('labResourceId')]" ],
      "properties": {
        "description": "VM filière Cybersécurité — Metasploit, Nmap/Masscan, sqlmap, Hydra, hashcat, Volatility 3, DVWA",
        "labVirtualMachineCreationParameter": {
          "size": "[variables('vmSizeCyber')]",
          "userName": "[parameters('adminUsername')]",
          "sshKey": "[parameters('sshPublicKey')]",
          "isAuthenticationWithSshKey": true,
          "labSubnetName": "Subnet",
          "disallowPublicIpAddress": false,
          "storageType": "Premium",
          "osDiskSizeGiB": "[variables('osDiskSizeGiB')]",
          "galleryImageReference": "[variables('ubuntuImage')]",
          "notes": "Cybersécurité — Metasploit, Nmap, Masscan, Burp Suite, sqlmap, Hydra, hashcat, Volatility, DVWA"
        }
      }
    }

  ],

  "outputs": {
    "labName":     { "type": "string", "value": "[parameters('labName')]" },
    "labId":       { "type": "string", "value": "[variables('labResourceId')]" },
    "portalUrl":   { "type": "string", "value": "https://labs.azure.com" }
  }
}
